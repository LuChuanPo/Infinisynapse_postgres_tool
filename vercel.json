{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "server.mjs": {
      "includeFiles": "public/**",
      "maxDuration": 60
    },
    "api/index.js": {
      "maxDuration": 60
    }
  }
}
