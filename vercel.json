{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "other",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.mjs": {
      "maxDuration": 60
    }
  }
}
